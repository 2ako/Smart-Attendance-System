import { 
    Chromosome, 
    Gene, 
    SchedulerInput, 
    DAYS, 
    SLOTS_PER_DAY, 
    SLOT_DURATION,
    getRoomType,
    isRoomTypeCompatible,
    isAfternoonAllowed
} from "./types";
import { evaluateFitness, repairChromosome, EvaluationBuffers } from "./constraints";

// Pre-allocate diagnostic buffers to avoid GC pressure in tight loops
const PROF_BUF = new BigUint64Array(1000);
const ROOM_BUF = new BigUint64Array(1000);
const LEVEL_BUF = new Uint32Array(200 * 36);
const SPEC_BUF = new Uint32Array(500 * 36);

const SHARED_BUFFERS: EvaluationBuffers = {
    profOccupancy: PROF_BUF,
    roomOccupancy: ROOM_BUF,
    levelMasks: LEVEL_BUF,
    specMasks: SPEC_BUF
};

const PROF_DAY_BUF = new Uint8Array(1000);
const SUBJ_DAY_BUF = new Uint8Array(2000);

export class SchedulerEngine {
    private input: SchedulerInput;
    private population: Chromosome[] = [];
    private populationSize = 60;
    private generations = 150; 
    private stagnationLimit = 30; 
    private profMap = new Map<string, number>();
    private roomMap = new Map<string, number>();
    private levelMap = new Map<string, number>();
    private specMap = new Map<string, number>();
    private subjectMap = new Map<string, number>();
    
    // Restored properties
    private tabuList: string[] = [];
    private tabuSize = 10;
    private specialtyGroupCounts = new Map<string, number>();
    private generationsSinceImprovement = 0;
    private bestFitness = Infinity;

    constructor(input: SchedulerInput) {
        this.input = input;
    }

    public async generate(): Promise<Chromosome> {
        console.time("SchedulerGen");
        
        // 1. Data Normalization & Legacy Cleanup
        this.input.subjects = this.input.subjects.map(s => {
            const groups = (s.groups || []).map((g: string) => 
                (g?.toLowerCase().trim() === "all" || g?.toLowerCase().trim() === "toutes") ? "All" : g
            );
            return {
                ...s,
                groups,
                // Ensure we don't accidentally respect random manual IDs from previous UI states
                // and clear scheduleInfo to start fresh
                scheduleInfo: null 
            };
        });

        // 2. Initialize Index Maps
        this.profMap.clear();
        this.input.professors.forEach((p, idx) => this.profMap.set(this.getId(p), idx));
        
        this.roomMap.clear();
        this.input.rooms.forEach((r, idx) => this.roomMap.set(r.name, idx));
        
        const levels = new Set<string>();
        const specs = new Set<string>();
        this.input.subjects.forEach(s => {
            levels.add(this.getId(s.level));
            specs.add(this.getId(s.specialty));
        });
        
        this.levelMap.clear();
        Array.from(levels).forEach((l, idx) => this.levelMap.set(l, idx));
        
        this.specMap.clear();
        Array.from(specs).forEach((s, idx) => this.specMap.set(s, idx));

        this.subjectMap.clear();
        this.input.subjects.forEach((s, idx) => this.subjectMap.set(this.getId(s), idx));

        const totalRooms = this.input.rooms.length;
        const totalSlots = DAYS.length * SLOTS_PER_DAY;
        
        // ... (rest of pre-calc)
        this.specialtyGroupCounts.clear();
        const specToGroups = new Map<string, Set<string>>();
        this.input.subjects.forEach(s => {
            const lid = this.getId(s.level);
            const sid = this.getId(s.specialty);
            const base = `${lid}@@@${sid}`;
            if (!specToGroups.has(base)) specToGroups.set(base, new Set());
            (s.groups || []).forEach((g: string) => {
                if (g && g !== "All") specToGroups.get(base)!.add(g);
            });
        });
        specToGroups.forEach((groups, spec) => {
            this.specialtyGroupCounts.set(spec, groups.size || 1); 
        });

        const expandedSubjects: any[] = [];
        this.input.subjects.forEach(sub => {
            const subType = (sub.type || "").toLowerCase();
            if (subType === "cours" || subType === "amphi") {
                expandedSubjects.push(sub);
            } else {
                const subGroups = sub.groups || [];
                if (subGroups.length > 0 && !subGroups.includes("All")) {
                    subGroups.forEach((g: string) => {
                        expandedSubjects.push({ ...sub, groups: [g] });
                    });
                } else {
                    expandedSubjects.push(sub);
                }
            }
        });
        this.input.subjects = expandedSubjects;

        this.initializePopulation();
        this.bestFitness = this.population[0]?.fitness || Infinity;
        this.generationsSinceImprovement = 0;

        try {
            for (let g = 0; g < this.generations; g++) {
                this.evolve(g);
                
                // Track improvement
                const currentBest = this.population[0]?.fitness || Infinity;
                if (currentBest < this.bestFitness) {
                    this.bestFitness = currentBest;
                    this.generationsSinceImprovement = 0;
                } else {
                    this.generationsSinceImprovement++;
                }
            }
        } catch (err) {
            console.error("[Scheduler] Evolution loop crashed:", err);
        }

        if (this.population.length === 0) {
            console.error("[Scheduler] Population is empty after evolution!");
            return { genes: [], fitness: Infinity, conflicts: ["Empty population"] };
        }

        // Final thorough evaluation with details
        SHARED_BUFFERS.profOccupancy.fill(0n);
        SHARED_BUFFERS.roomOccupancy.fill(0n);
        SHARED_BUFFERS.levelMasks.fill(0);
        SHARED_BUFFERS.specMasks.fill(0);

        let best = this.population[0];
        try {
            best = repairChromosome(this.population[0], this.input.rooms);
            // Pass shared buffers and include details
            best = evaluateFitness(best, true, SHARED_BUFFERS);
        } catch (err) {
            console.error("[Scheduler] Repair logic crashed:", err);
            best = evaluateFitness(this.population[0], true, SHARED_BUFFERS);
        }
        
        console.timeEnd("SchedulerGen");
        return best;
    }

    private getGroupMask(groups: string[], type: string): number {
        const normalized = (groups || []).map(g => g?.trim().toLowerCase());
        if (normalized.includes("all") || type === "Cours" || type === "Amphi") {
            return 0xFFFF;
        }
        let mask = 0;
        for (const g of normalized) {
            const match = g.match(/\d+/);
            if (match) mask |= (1 << parseInt(match[0]));
        }
        return mask || 0xFFFF; // Default to all if no numeric groups found but groups exist
    }

    private normalizeField(field: any): string {
        if (!field) return "";
        let val = "";
        if (typeof field === "string") val = field;
        else if (typeof field === "object") val = field.code || field.name || "";
        
        const f = val.toLowerCase().trim();
        if (f === "info" || f === "informatique") return "informatique";
        return f;
    }

    private getCompatibleRooms(sessionType: string, studyField?: string, groups: string[] = [], specialtyGroupCount?: number): any[] {
        let compatible = this.input.rooms.filter(r => {
            const roomType = getRoomType(r.name);
            return isRoomTypeCompatible(sessionType, roomType, groups, specialtyGroupCount);
        });

        if (studyField && compatible.length > 0) {
            const fieldMatched = compatible.filter(r => {
                const rf = this.normalizeField(r.studyField?.code || r.studyField?.name || r.studyField || "");
                const sf = this.normalizeField(studyField);
                return rf === "" || rf === "all" || rf === "common" || rf === sf;
            });
            if (fieldMatched.length > 0) return fieldMatched;
        }

        if (compatible.length === 0) return this.input.rooms;
        return compatible;
    }

    private getId(val: any): string {
        if (!val) return "";
        if (typeof val === 'string') return val;
        return val._ref || val._id || "";
    }

    private getLevelName(val: any): string {
        if (!val) return "";
        if (typeof val === 'string') return val;
        return val.name || val.code || val._ref || val._id || "";
    }

    private createGene(sub: any, group: string | string[], targetSlot: number, blockId?: string): Gene {
        const subjectStudyField = sub.studyField?.code || sub.studyField?.name || sub.studyField || "";
        const groups = Array.isArray(group) ? group : [group];
        
        const lid = this.getId(sub.level);
        const sid = this.getId(sub.specialty);
        const specKey = `${lid}@@@${sid}`;
        const specCount = this.specialtyGroupCounts.get(specKey) || 1;

        const suitableRooms = this.getCompatibleRooms(sub.type || "Cours", subjectStudyField, groups, specCount);
        const rIdx = Math.floor(Math.random() * suitableRooms.length);
        const room = suitableRooms[rIdx];

        return {
            subjectId: sub._id,
            subjectName: sub.name,
            professorId: this.getId(sub.professor),
            professorName: sub.professor ? (
                (sub.professor.firstName || sub.professor.lastName) 
                ? `${sub.professor.firstName || ""} ${sub.professor.lastName || ""}`.trim()
                : sub.professor.user?.name || "Unknown"
            ) : "Unknown",
            roomId: room?.name || "UNKNOWN_ROOM",
            roomStudyField: room?.studyField?.code || room?.studyField?.name || "",
            slotId: targetSlot,
            studyField: typeof subjectStudyField === "string" ? subjectStudyField : "",
            level: lid,
            levelName: this.getLevelName(sub.level),
            specialty: sid,
            specialtyName: this.getLevelName(sub.specialty),
            specialtyGroupCount: specCount,
            type: sub.type || "Cours",
            groups,
            blockId,
            // Performance indices
            profIdx: this.profMap.get(this.getId(sub.professor)) ?? -1,
            roomIdx: this.roomMap.get(room?.name) ?? -1,
            levelIdx: this.levelMap.get(lid) ?? -1,
            specIdx: this.specMap.get(sid) ?? -1,
            subjectIdx: this.subjectMap.get(sub._id) ?? -1,
            groupMask: this.getGroupMask(groups, sub.type || "Cours")
        };
    }

    private initializePopulation() {
        console.log("[Scheduler] Starting smart greedy initialization...");
        this.population = [];

        for (let i = 0; i < this.populationSize; i++) {
            const genes: Gene[] = [];
            const occupied = new Set<string>(); // slot-room, slot-prof, slot-group
            
            // Priority subjects: Afternoon restricted (L3, M1, M2)
            const prioritySubjects = this.input.subjects.filter(s => !isAfternoonAllowed(this.getLevelName(s.level)));
            const others = this.input.subjects.filter(s => isAfternoonAllowed(this.getLevelName(s.level)));

            const allSubs = [...prioritySubjects, ...others];
            
            for (const sub of allSubs) {
                let found = false;
                const sid = this.getId(sub.specialty);
                const lid = this.getId(sub.level);
                const pid = this.getId(sub.professor);
                const subGroups = sub.groups || [];

                // Try days in order, Saturday LAST
                const daysToTry = [1, 2, 3, 4, 5, 0]; 

                for (const dayIdx of daysToTry) {
                    // Bias against Saturday for most chromosomes (Stronger: 99% of population ignores Saturday initially)
                    if (dayIdx === 0 && i < this.populationSize * 0.99) continue;

                    for (let s = 0; s < SLOTS_PER_DAY; s++) {
                        const slotId = dayIdx * SLOTS_PER_DAY + s;
                        
                        // Strict level-based afternoon check (After 2:00 PM means Slot 4, 5)
                        if (s >= 4 && !isAfternoonAllowed(this.getLevelName(sub.level))) continue;
                        
                        const profKey = `${slotId}@@@prof@@@${pid}`;
                        if (pid && occupied.has(profKey)) continue;

                        let groupConflict = false;
                        for (const g of subGroups) {
                            if (occupied.has(`${slotId}@@@group@@@${lid}@@@${sid}@@@${g}`)) {
                                groupConflict = true; break;
                            }
                        }
                        if (groupConflict) continue;

                        const suitableRooms = this.getCompatibleRooms(sub.type, sub.studyField, subGroups, this.specialtyGroupCounts.get(`${lid}@@@${sid}`));
                        const room = suitableRooms.find(r => !occupied.has(`${slotId}@@@room@@@${r.name}`));
                        
                        if (room) {
                            const gene = this.createGene(sub, subGroups, slotId);
                            gene.roomId = room.name;
                            gene.roomIdx = this.roomMap.get(room.name) ?? -1;
                            genes.push(gene);
                            
                            occupied.add(`${slotId}@@@room@@@${room.name}`);
                            if (pid) occupied.add(profKey);
                            subGroups.forEach((g: string) => occupied.add(`${slotId}@@@group@@@${lid}@@@${sid}@@@${g}`));
                            
                            found = true;
                            break;
                        }
                    }
                    if (found) break;
                }

                if (!found) {
                    // Strictly NO afternoon for restricted levels, even in fallback.
                    const restricted = !isAfternoonAllowed(this.getLevelName(sub.level));
                    let fallbackSlot: number;
                    if (restricted) {
                        // Pick a random MORNING slot (0, 1, 2, 3 across all days)
                        const morningSlots = [0, 1, 2, 3, 6, 7, 8, 9, 12, 13, 14, 15, 18, 19, 20, 21, 24, 25, 26, 27, 30, 31, 32, 33];
                        fallbackSlot = morningSlots[Math.floor(Math.random() * morningSlots.length)];
                    } else {
                        fallbackSlot = Math.floor(Math.random() * (DAYS.length * SLOTS_PER_DAY));
                    }
                    genes.push(this.createGene(sub, subGroups, fallbackSlot));
                }
            }
            this.population.push(evaluateFitness({ genes, fitness: 0, conflicts: [] }, false));
        }
        this.sortPopulation();
    }

    private evolve(generation: number) {
        if (this.population.length === 0) return;
        
        const newPopulation: Chromosome[] = this.population.slice(0, 10); // Elite set
        
        // Heat-based Mutation: If stalled, crank up the heat
        let mutationRate = 0.1;
        if (this.generationsSinceImprovement > 20) {
            mutationRate = 0.4; // High heat for extreme diversity
        } else if (this.generationsSinceImprovement > 10) {
            mutationRate = 0.2;
        }

        while (newPopulation.length < this.populationSize) {
            let child: Chromosome;
            if (Math.random() < 0.7) {
                const p1 = this.tournamentSelect();
                const p2 = this.tournamentSelect();
                child = this.crossover(p1, p2);
                if (Math.random() < mutationRate) this.mutate(child);
            } else {
                child = { ...this.tournamentSelect() };
                this.mutate(child);
            }

            SHARED_BUFFERS.profOccupancy.fill(0n);
            SHARED_BUFFERS.roomOccupancy.fill(0n);
            SHARED_BUFFERS.levelMasks.fill(0);
            SHARED_BUFFERS.specMasks.fill(0);
            newPopulation.push(evaluateFitness(child, false, SHARED_BUFFERS));
        }
        
        this.population = newPopulation;
        this.sortPopulation();
        
        // Local Search (Tabu) on the best individual every 8 generations
        if (generation % 8 === 0 && this.population.length > 0) {
            try {
                this.population[0] = this.performTabuSearch(this.population[0]);
                this.sortPopulation();
            } catch (tabuErr) {
                console.error("[Scheduler] Tabu Search crashed:", tabuErr);
            }
        }
    }

    private tournamentSelect(): Chromosome {
        if (this.population.length === 0) return { genes: [], fitness: Infinity, conflicts: [] };
        const tSize = 3;
        let best = this.population[Math.floor(Math.random() * this.population.length)];
        for (let i = 1; i < tSize; i++) {
            const next = this.population[Math.floor(Math.random() * this.population.length)];
            if (next && next.fitness < best.fitness) best = next;
        }
        return best;
    }

    private crossover(p1: Chromosome, p2: Chromosome): Chromosome {
        const midpoint = Math.floor(p1.genes.length / 2);
        const genes = [...p1.genes.slice(0, midpoint), ...p2.genes.slice(midpoint)];
        return { genes, fitness: 0, conflicts: [] };
    }

    private mutate(chromosome: Chromosome): Chromosome {
        const genes = [...chromosome.genes];
        const mutationRate = 0.2; // High exploration
        
        // 1. Random Mutation (Standard Explorer)
        for (let i = 0; i < genes.length; i++) {
            if (Math.random() < mutationRate) {
                const totalSlots = DAYS.length * SLOTS_PER_DAY;
                if (!isAfternoonAllowed(this.getLevelName(genes[i].level))) {
                    const morningSlots = [0, 1, 2, 3, 6, 7, 8, 9, 12, 13, 14, 15, 18, 19, 20, 21, 24, 25, 26, 27, 30, 31, 32, 33];
                    genes[i] = { ...genes[i], slotId: morningSlots[Math.floor(Math.random() * morningSlots.length)] };
                } else {
                    genes[i] = { ...genes[i], slotId: Math.floor(Math.random() * totalSlots) };
                }
                
                const suitableRooms = this.getCompatibleRooms(genes[i].type, genes[i].studyField, genes[i].groups || []);
                if (suitableRooms.length > 0) {
                    const newRoom = suitableRooms[Math.floor(Math.random() * suitableRooms.length)];
                    genes[i].roomId = newRoom.name;
                    genes[i].roomIdx = this.roomMap.get(newRoom.name) ?? -1;
                }
            }
        }

        // 2. "Smart Rescue" (Targeted Conflict Resolution)
        // If the chromosome has many hard conflicts, try to "rescue" a few genes involved in overlaps
        const currentStats = chromosome.stats || evaluateFitness(chromosome, false).stats;
        if (currentStats && currentStats.hardConflicts > 0) {
            const rescueCount = Math.min(3, currentStats.hardConflicts);
            for (let r = 0; r < rescueCount; r++) {
                const idx = Math.floor(Math.random() * genes.length);
                const gene = genes[idx];
                
                // Find a slot that currently has NO overlap for this gene's PROF and ROOM
                // This is a simplified local search within mutation
                const totalSlots = DAYS.length * SLOTS_PER_DAY;
                for (let attempt = 0; attempt < 10; attempt++) {
                    const testSlot = Math.floor(Math.random() * totalSlots);
                    if (!isAfternoonAllowed(this.getLevelName(gene.level)) && (testSlot % SLOTS_PER_DAY >= 4)) continue;
                    
                    // Simple check against current genes (not exhaustive but helps)
                    const isOccupied = genes.some(g => g.slotId === testSlot && (g.professorId === gene.professorId || g.roomId === gene.roomId));
                    if (!isOccupied) {
                        genes[idx] = { ...gene, slotId: testSlot };
                        break;
                    }
                }
            }
        }
        
        return { ...chromosome, genes };
    }

    private performTabuSearch(chromosome: Chromosome): Chromosome {
        let best = { ...chromosome };
        for (let i = 0; i < 50; i++) {
            const neighbors = this.generateNeighbors(best);
            const filteredNeighbors = neighbors.filter(n => !this.tabuList.includes(this.getHash(n)));
            if (filteredNeighbors.length === 0) break;
            const nextBest = filteredNeighbors.sort((a, b) => a.fitness - b.fitness)[0];
            if (nextBest && nextBest.fitness < best.fitness) {
                best = nextBest;
                this.updateTabuList(this.getHash(best));
            } else {
                break;
            }
        }
        return best;
    }

    private generateNeighbors(chromosome: Chromosome): Chromosome[] {
        const neighbors: Chromosome[] = [];
        for (let i = 0; i < 5; i++) {
            const genes = [...chromosome.genes];
            const idx = Math.floor(Math.random() * genes.length);
            genes[idx] = { ...genes[idx], slotId: Math.floor(Math.random() * (DAYS.length * SLOTS_PER_DAY)) };
            neighbors.push(evaluateFitness({ genes, fitness: 0, conflicts: [] }, false));
        }
        return neighbors;
    }

    private sortPopulation() {
        this.population.sort((a, b) => a.fitness - b.fitness);
    }

    private getHash(c: Chromosome): string {
        if (!c || !c.genes) return "";
        let hash = "";
        for (let i = 0; i < c.genes.length; i++) {
            const gene = c.genes[i];
            const slot = gene?.slotId ?? 0;
            const room = gene?.roomIdx ?? 0;
            // Interleave slot and room in base36 for compactness
            hash += slot.toString(36) + room.toString(36);
        }
        return hash;
    }

    private updateTabuList(hash: string) {
        this.tabuList.push(hash);
        if (this.tabuList.length > this.tabuSize) this.tabuList.shift();
    }
}
